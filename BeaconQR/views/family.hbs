<div class="family-portal">
    <h1>Family Monitoring: {{client.name}}</h1>
    <p class="form-label"> QR ID: {{client.qrID}}</p>
    <hr>

    <div class="status-container">
        {{#if activeRecently}}
            <div class="status-indicator status-active">
                <span class="dot"></span> 
                <h2>ACTIVE</h2>
                <p>Checked in within last 24 hours.</p>
            </div>
        {{else}}
            <div class="status-indicator status-inactive">
                <span class="dot"></span>
                <h2>INACTIVE</h2>
                <p>No check-in recorded in the last 24 hours.</p>

            </div>
        {{/if}}
    </div>
    <div class="details-box">
        <p><strong>Last Seen:</strong> {{client.lastSeen}}</p>
        <p><strong>Last Need:</strong> {{client.lastNeed}}</p>
    </div>
</div>