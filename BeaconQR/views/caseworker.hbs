<div class="dashboard-container">
  {{> caseworkerNav}} 
  
  <header class="dashoard-header">
    <h1>Caseworker Dashboard</h1>
    <p>Monitoring all active Beacon Beacons</p>
  </header>

  <div class="table-responsive">
    <table class="caseworker-table">
      <thead>
        <tr class="table-header-row">
          <th>Client Name</th>
          <th>QR ID</th>
          <th>Status</th>
          <th>Last Seen</th>
          <th>Last Need</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each clients}}
        <tr>
          <td class="client-name"><strong>{{this.name}}</strong></td>
          <td><code class="qr-badge">{{this.qrID}}</code></td>
          <td>
            {{#if this.activeRecently}}
              <span class="status-pill active">ACTIVE</span>
            {{else}}
              <span class="status-pill inactive">INACTIVE</span>
            {{/if}}
          </td>
          <td class="time-text">{{formatDate this.lastSeen}}</td>
          <td>
            <span class="need-text {{#ifCond this.lastNeed '===' 'CaseWorker'}}urgent-text{{/ifCond}}">
              {{this.lastNeed}}
            </span>
          </td>
          <td>
              <a href="/family/{{this.qrID}}" class="view-link-btn">View Profile</a>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>
